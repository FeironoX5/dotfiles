// Zed Settings
{
  // =========================================================
  // APPEARANCE
  // =========================================================
  "ssh_connections": [
    {
      "host": "helios.cs.ifmo.ru",
      "args": [],
      "projects": []
    }
  ],
  "which_key": {
    "enabled": false,
  },
  "theme": "GitHub Dark",
  "icon_theme": "JetBrains New UI Icons (Dark)",

  // Fonts
  "ui_font_family": "Lato",
  "ui_font_size": 14,
  "ui_font_weight": 450.0,
  "buffer_font_family": "Ioskeley Mono",
  "buffer_font_size": 13,
  "buffer_line_height": "standard",

  // Layout
  "resize_all_panels_in_dock": ["left", "bottom", "right"],
  "centered_layout": {
    "right_padding": 0.0,
    "left_padding": 0.0,
  },
  "current_line_highlight": "all",
  "colorize_brackets": true,
  "show_whitespaces": "all",
  "relative_line_numbers": "disabled",
  "soft_wrap": "none",
  "wrap_guides": [90],
  "show_wrap_guides": true,
  "active_pane_modifiers": {
    "inactive_opacity": 0.7,
  },

  // Minimap
  "minimap": {
    "show": "always",
    "display_in": "all_editors",
    "thumb_border": "none",
    "thumb": "always",
    "max_width_columns": 50,
  },

  // Scrollbar
  "scrollbar": {
    "show": "never",
    "axes": {
      "vertical": true,
      "horizontal": false,
    },
    "cursors": false,
  },

  // Indent guides
  "indent_guides": {
    "active_line_width": 2,
    "line_width": 2,
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },

  // Cursor
  "cursor_shape": "bar",

  // =========================================================
  // EDITOR BEHAVIOR
  // =========================================================
  "base_keymap": "JetBrains",
  "vim_mode": false,
  "tab_size": 4,
  "autosave": "on_focus_change",
  "format_on_save": "off",
  "formatter": "prettier",
  "remove_trailing_whitespace_on_save": true,
  "always_treat_brackets_as_autoclosed": true,
  "double_click_in_multibuffer": "open",
  "autoscroll_on_clicks": true,
  "middle_click_paste": false,
  "fast_scroll_sensitivity": 6.0,
  "seed_search_query_from_cursor": "selection",
  "use_smartcase_search": true,
  "restore_on_startup": "last_workspace",
  "file_scan_exclusions": [],

  // Completions
  "completions": {
    "words": "enabled",
  },
  "completion_detail_alignment": "right",
  "completion_menu_scrollbar": "auto",
  "snippet_sort_order": "top",

  // Signature help
  "auto_signature_help": true,
  "show_signature_help_after_edits": true,

  // Hover
  "hover_popover_delay": 200,

  // Sticky scroll
  "sticky_scroll": {
    "enabled": true,
  },

  // Inlay hints
  "inlay_hints": {
    "enabled": true,
    "show_background": true,
    "edit_debounce_ms": 700,
  },

  // Search
  "search": {
    "center_on_match": true,
  },

  // File finder
  "file_finder": {
    "modal_max_width": "large",
  },

  // =========================================================
  // UI PANELS & DOCKS
  // =========================================================
  "toolbar": {
    "code_actions": false,
    "agent_review": false,
    "quick_actions": false,
    "breadcrumbs": false,
    "selections_menu": false,
  },

  "tabs": {
    "file_icons": true,
    "git_status": true,
  },

  "title_bar": {
    "show_onboarding_banner": false,
    "show_sign_in": false,
  },

  "gutter": {
    "folds": false,
    "breakpoints": false,
    "runnables": false,
    "min_line_number_digits": 3,
  },

  "project_panel": {
    "dock": "right",
    "auto_fold_dirs": true,
  },

  "outline_panel": {
    "dock": "left",
    "indent_size": 25,
  },

  "notification_panel": {
    "button": false,
  },

  "collaboration_panel": {
    "button": false,
  },

  // =========================================================
  // GIT
  // =========================================================
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500,
      "min_column": 80,
    },
  },

  "git_panel": {
    "tree_view": true,
  },

  // =========================================================
  // TERMINAL
  // =========================================================
  "terminal": {
    "dock": "bottom",
    "shell": {
      "program": "zsh",
    },
    "blinking": "on",
    "copy_on_select": true,
    "toolbar": {
      "breadcrumbs": true,
    },
    "env": {
      "EDITOR": "zed --wait",
    },
    "detect_venv": {
      "on": {
        "directories": [".venv", "venv"],
        "activate_script": "default",
      },
    },
  },

  // =========================================================
  // AI / AGENT
  // =========================================================
  "disable_ai": false,
  "agent_ui_font_size": 13.0,

  "agent": {
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": false
      }
    ],
    "dock": "bottom",
    "default_profile": "write",
    "profiles": {},
    "default_view": "thread",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "inline_assistant_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b-base",
    },
    "use_modifier_to_send": true,
    "show_turn_stats": true,
    "enable_feedback": false,
    "play_sound_when_agent_done": false,
  },

  "agent_servers": {
    "opencode": {
      "favorite_models": ["ollama/llama3.2", "ollama/ministral-3"],
      "type": "registry",
      "default_mode": "plan",
      "default_model": "ollama/ministral-3",
    },
  },

  // Edit predictions
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
    "ollama": {
      "model": "deepseek-coder:latest",
      // "model": "qwen2.5-coder:7b-base",
    },
    "mode": "eager",
    "enabled_in_text_threads": true,
  },

  // =========================================================
  // EXTENSIONS & LANGUAGES
  // =========================================================
  "prettier": {
    "allowed": true,
  },

  "file_types": {
    "Prolog": ["pl", "pro"],
  },

  "languages": {
    "TypeScript": {
      "language_servers": ["angular", "vtsls", "deno"],
    },
    "JavaScript": {
      "language_servers": ["vtsls", "deno"],
    },
    "HTML": {
      "language_servers": ["angular", "html"],
    },
    "JSON": {
      "formatter": "language_server",
    },
  },

  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "never",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "never",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "jdtls": {
      "settings": {
        "java_home": "/usr/lib/jvm/java-21-openjdk",
      },
    },
  },

  "auto_install_extensions": {
    "dart": true,
    "fleet-themes": true,
    "git-firefly": true,
    "html": true,
    "ruff": true,
    "toml": true,
  },

  // =========================================================
  // CONTEXT SERVERS (MCP)
  // =========================================================
  // Tokens are stored in ~/.config/secrets/ (gitignored, outside dotfiles).
  // To initialise: bash ~/.dotfiles/scripts/setup-mcp-secrets.sh
  "context_servers": {
    "mcp-server-github": {
      // Reads GITHUB_PERSONAL_ACCESS_TOKEN from ~/.config/secrets/github_token
      "command": "bash",
      "args": ["-c", "exec $HOME/.config/zed/mcp-wrappers/github.sh"],
      "enabled": true,
    },
    "todoist": {
      // Reads TODOIST_API_TOKEN from ~/.config/secrets/todoist_token
      "command": "bash",
      "args": ["-c", "exec $HOME/.config/zed/mcp-wrappers/todoist.sh"],
      "enabled": true,
    },
  },

  // =========================================================
  // PRIVACY & TELEMETRY
  // =========================================================
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "session": {
    "trust_all_worktrees": true,
  },

  "theme_overrides": {
    "GitHub Dark": {
      "border": "#14181e",
      // "border": "#30363D66",
      // "editor.background": "#010409",
      "text.muted": "#7D8590BB",
      "editor.line_number": "#6E768155",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
      },
    },
  },

  // etc
  // "debugger": {
  //     "stepping_granularity": "line",
  //     "log_dap_communications": true,
  //     "format_dap_log_messages": true,
  // },
  // "dap": {
  //   "JavaScript": {
  //     "binary": "node",
  //     "args": ["/home/glebkiva/scripts/nodestuff/.deno-dap-bridge.js"]
  //   }
  // }
  // "dap": {
  // "JavaScript": {
  //
  // }
  // }
}
